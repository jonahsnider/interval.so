{
	"name": "@interval.so/api",
	"version": "0.0.0",
	"private": true,
	"license": "UNLICENSED",
	"type": "module",
	"imports": {
		"#controllers/*": "./app/controllers/*.js",
		"#exceptions/*": "./app/exceptions/*.js",
		"#models/*": "./app/models/*.js",
		"#mails/*": "./app/mails/*.js",
		"#services/*": "./app/services/*.js",
		"#listeners/*": "./app/listeners/*.js",
		"#events/*": "./app/events/*.js",
		"#middleware/*": "./app/middleware/*.js",
		"#validators/*": "./app/validators/*.js",
		"#providers/*": "./providers/*.js",
		"#policies/*": "./app/policies/*.js",
		"#abilities/*": "./app/abilities/*.js",
		"#generated/*": "./.adonisjs/server/*.js",
		"#transformers/*": "./app/transformers/*.js",
		"#database/*": "./database/*.js",
		"#start/*": "./start/*.js",
		"#config/*": "./config/*.js"
	},
	"scripts": {
		"build": "node ace build",
		"dev": "PORT=3001 node ace serve --hmr",
		"dev:debug": "PORT=3001 node --inspect ace serve --hmr",
		"migrate:apply": "drizzle-kit migrate",
		"migrate:create": "drizzle-kit generate",
		"start": "node bin/server.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@adonisjs/auth": "10.1.0",
		"@adonisjs/bouncer": "4.0.0",
		"@adonisjs/core": "7.3.5",
		"@adonisjs/cors": "3.0.0",
		"@adonisjs/redis": "10.0.0",
		"@adonisjs/session": "8.1.0",
		"@jonahsnider/util": "13.0.0",
		"@paralleldrive/cuid2": "3.3.0",
		"@rlanz/sentry": "^0.3.3",
		"@sentry/node": "10.67.0",
		"@sentry/profiling-node": "10.67.0",
		"@simplewebauthn/server": "13.3.2",
		"@trpc/server": "11.18.0",
		"@vinejs/vine": "4.4.0",
		"convert": "7.0.0",
		"crypto-random-string": "5.0.0",
		"date-fns": "4.4.0",
		"drizzle-kit": "0.31.10",
		"drizzle-orm": "0.45.2",
		"postgres": "3.4.9",
		"posthog-node": "5.45.2",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"superjson": "2.2.6",
		"ts-pattern": "5.9.0",
		"ws": "8.21.1",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@adonisjs/assembler": "8.4.0",
		"@adonisjs/tsconfig": "2.0.0",
		"@poppinss/ts-exec": "1.4.4",
		"@types/node": "24.13.3",
		"@types/pg": "8.20.0",
		"@types/ws": "8.18.1",
		"dotenv": "17.4.2",
		"execa": "10.0.0",
		"hot-hook": "1.0.0",
		"pino-pretty": "13.1.3",
		"prettier": "3.9.5",
		"typescript": "6.0.3",
		"youch": "4.1.1"
	},
	"packageManager": "yarn@4.17.1",
	"engines": {
		"node": "24.x"
	},
	"hotHook": {
		"boundaries": [
			"./app/controllers/**/*.ts",
			"./app/routers/**/*.ts",
			"./app/**/*_controller.ts",
			"./app/**/*_router.ts",
			"./app/middleware/*.ts"
		]
	}
}
